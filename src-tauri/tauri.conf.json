{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zeelo Desktop",
  "version": "0.3.0",
  "identifier": "com.zeelo.desktop",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../zeelo/packages/client/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Zeelo Desktop",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "visible": false
      },
      {
        "label": "splash",
        "title": "Zeelo",
        "width": 340,
        "height": 260,
        "resizable": false,
        "decorations": false,
        "center": true,
        "url": "/updater"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://chat.zeelo.fun/api/update/{{target}}/{{current_version}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQzOEI0QzRGNjI1OTYwMjYKUldRbVlGbGlUMHlMMDN6UU5xQ09RKzBZQWRTSlljQjNQMXdjbEVpQUJPQ1BUTEQvQkZvUnU4eXMK"
    }
  }
}